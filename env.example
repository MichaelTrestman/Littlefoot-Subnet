# Littlefoot Subnet Configuration
# Copy this file to .env and update the values

# Network Configuration
NETWORK=finney          # finney (mainnet), test (testnet), or local
NETUID=1                # Your subnet's netuid

# Wallet Configuration
WALLET_NAME=default     # Name of your wallet
HOTKEY_NAME=default     # Name of your hotkey

# Target Subnets (for fetching subnet weights)
LIUM_NETUID=51          # Lium subnet netuid
CHUTES_NETUID=64        # Chutes subnet netuid

# Logging
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR

# Optional: API Keys for location verification
# LATITUDE_API_KEY=your_latitude_api_key
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# GCP_CREDENTIALS_PATH=/path/to/gcp/credentials.json
